# Google Cloud Text-to-Speech Configuration
# 1. Download your service account JSON key from Google Cloud Console
# 2. Rename it to something like: guardiansathi-tts-key.json
# 3. Place it in this folder
# 4. Update the path below (use ./ for current directory)

GOOGLE_APPLICATION_CREDENTIALS=./guardiansathi-tts-key.json
PORT=5000

# Important: Never commit the actual .env file or the JSON key to GitHub!
# Add them to .gitignore
